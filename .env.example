
# OpenAI is optional. Without a key, the app uses the local fallback email text.
APP_NAME="Reservation System"
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
USE_OPENAI_EMAILS=true
DATABASE_URL=sqlite:///reservation_system.db
MAIL_PROVIDER=smtp
MAIL_HOST=smtps.udag.de
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_USE_TLS=true
MAIL_USE_SSL=false
MAIL_DEFAULT_SENDER=
CONDITIONS_DELAY_MINUTES=10
CONDITIONS_REMINDER_DAYS=1
JOB_RUNNER_INTERVAL=10
OFFER_REMINDER_DAYS=2
CALENDAR_PROVIDER=internal
LOG_LEVEL=INFO